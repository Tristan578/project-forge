# =============================================================================
# AutoForge Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# This file is committed to git; .env is NOT.

# --- Authentication (choose ONE) ---

# Option 1: Vercel AI Gateway (RECOMMENDED — routes to any model provider)
# Get your key from Vercel Dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Option 2: Direct Anthropic API key (fallback if no AI Gateway)
# ANTHROPIC_API_KEY=

# Note: For the Claude Code experiment loop itself, your Max subscription
# handles auth automatically (you're already logged in via `claude /login`).
# The keys above are ONLY for vision scoring.

# --- Vision Model ---
# Uses AI Gateway format: "provider/model-name"
# Cost and quality comparison:
#
#   Model                          Cost/call  Monthly(20exp)  Quality
#   google/gemini-3-flash          $0.006     ~$22            88%   ← DEFAULT
#   google/gemini-3.1-flash-lite   $0.003     ~$11            82%     Budget
#   google/gemini-3.1-pro          $0.023     ~$90            94%     Quality-first
#   anthropic/claude-sonnet-4.6    $0.032     ~$125           95%     Overkill
#
VISION_MODEL=google/gemini-3-flash

# --- AI Gateway URL (only change if self-hosting) ---
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh

# --- Paths (auto-detected from git root if not set) ---
# PROJECT_ROOT=
# RESULTS_DIR=
# ASSET_CACHE_DIR=

# --- Experiment Tuning ---
MAX_EXPERIMENTS=20
MAX_HOURS=6
DEV_SERVER_URL=http://localhost:3000
DEV_SERVER_WAIT=30

# --- Evaluation ---
# Heuristic score threshold — experiments scoring below this skip Vision eval
# Range: 0-60, default: 30
HEURISTIC_THRESHOLD=30

# --- Sentry Observability (optional) ---
# Create a separate Sentry project for autoforge agent traces
# SENTRY_DSN=
# SENTRY_PROJECT=spawnforge-autoforge

# --- Provider APIs (for Sunday weekly validation) ---
# Set these to enable real provider calls instead of cached assets
# MESHY_API_KEY=
# ELEVENLABS_API_KEY=
# SUNO_API_KEY=
