# ==============================================================================
# Project Forge .gitignore
# ==============================================================================

# ----- Environment & Secrets -----
.env
.env.*
!.env.example
*.pem
*.key
*.cert
credentials.json
secrets.json

# ----- Claude / AI Tooling -----
# Ignore .claude contents by default, then whitelist essentials
.claude/*
# Track project config, taskboard, skills, hooks, rules, agents
!.claude/CLAUDE.md
!.claude/rules/
!.claude/skills/
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
!.claude/taskboard.db
!.claude/TASKBOARD_SETUP.md
# Always ignore local settings and WAL files
.claude/settings.local.json
.claude/taskboard.db-wal
.claude/taskboard.db-shm
# Generated sync state — not for version control
.claude/hooks/github-project-map.json

# ----- Windsurf / AI Tooling -----
# Track Windsurf rules and workflows
!.windsurf/
!.windsurf/rules/
!.windsurf/workflows/
specs/
ARCHITECTURE.md
TESTING.md
project_board.json

# ----- Rust / Cargo -----
engine/target/
.transform-gizmo-fork/target/
engine/pkg/
engine/pkg-webgl2/
engine/pkg-webgpu/
engine/pkg-webgl2-runtime/
engine/pkg-webgpu-runtime/

# ----- WASM Build Artifacts -----
web/public/engine-pkg/
web/public/engine-pkg-webgl2/
web/public/engine-pkg-webgpu/
web/public/engine-pkg-webgl2-runtime/
web/public/engine-pkg-webgpu-runtime/

# ----- Node / npm -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Next.js -----
web/.next/
web/out/
web/test-results/
web/playwright-report/

# ----- TypeScript -----
*.tsbuildinfo

# ----- OS Files -----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
nul

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# ----- Session artifacts -----
PHASE-*.md
REFACTOR*.md
*-SUMMARY.md
*-PROGRESS.md
rust_errors.txt
*.backup
do_split.py
extract_handlers.py
split_commands*.py

# ----- Misc -----
*.log
*.pid
*.seed
*.pid.lock
.cache/
.claude/hooks/__pycache__/
