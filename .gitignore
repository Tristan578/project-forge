# ==============================================================================
# Project Forge .gitignore
# ==============================================================================

# ----- Environment & Secrets -----
.env
.env.*
!.env.example
*.pem
*.key
*.cert
credentials.json
secrets.json

# ----- Claude / AI Tooling -----
# Ignore .claude contents by default, then whitelist essentials
.claude/*
# Track project config, taskboard, skills, hooks, rules, agents
!.claude/CLAUDE.md
!.claude/rules/
!.claude/skills/
!.claude/agents/
!.claude/hooks/
!.claude/tools/
!.claude/settings.json
!.claude/TASKBOARD_SETUP.md
!.claude/docs/
# Always ignore local settings, DB, and WAL files
.claude/settings.local.json
.claude/taskboard.db
.claude/taskboard.db-wal
.claude/taskboard.db-shm
# Generated sync state — not for version control
.claude/hooks/github-project-map.json

# ----- Windsurf / AI Tooling -----
# Track Windsurf rules and workflows
!.windsurf/
!.windsurf/rules/
!.windsurf/workflows/
specs/
ARCHITECTURE.md
project_board.json

# ----- Rust / Cargo -----
engine/target/
.transform-gizmo-fork/target/
engine/pkg/
engine/pkg-webgl2/
engine/pkg-webgpu/
engine/pkg-webgl2-runtime/
engine/pkg-webgpu-runtime/

# ----- WASM Build Artifacts (intermediate) -----
# WASM engine binaries are hosted on CDN (Cloudflare R2), not committed to git.
# Set NEXT_PUBLIC_ENGINE_CDN_URL in production to point to the CDN origin.
web/public/engine-pkg-webgl2/
web/public/engine-pkg-webgpu/
web/public/engine-pkg-webgl2-runtime/
web/public/engine-pkg-webgpu-runtime/

# ----- Node / npm -----
node_modules/
web/package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Next.js -----
web/.next/
web/out/
web/test-results/
web/playwright-report/

# ----- Packages -----
packages/ui/dist/

# ----- TypeScript -----
*.tsbuildinfo

# ----- OS Files -----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
nul

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# ----- Session artifacts -----
PHASE-*.md
REFACTOR*.md
*-SUMMARY.md
*-PROGRESS.md
rust_errors.txt
*.backup
do_split.py
extract_handlers.py
split_commands*.py

# ----- AutoForge -----
autoforge/results/*
!autoforge/results/.gitkeep
autoforge/asset-cache/*
!autoforge/asset-cache/.gitkeep
autoforge/node_modules/

# ----- Misc -----
*.log
*.pid
*.seed
*.pid.lock
.cache/
.claude/hooks/__pycache__/

# Taskboard DB files — use OS default path, never commit
.claude/taskboard.db
.claude/taskboard.db-shm
.claude/taskboard.db-wal

# Generated MCP command pages (regenerated on every build)
apps/docs/content/mcp/*.mdx
.vercel
.claude/.env-health-last-check
