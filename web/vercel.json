{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd .. && npm ci && npm run build --workspace=packages/ui",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/cron/health-monitor",
      "schedule": "*/5 * * * *"
    }
  ]
}
