# =============================================================================
# SpawnForge Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/forge?sslmode=require

# -----------------------------------------------------------------------------
# Clerk Authentication — REQUIRED
# Get keys at: https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# -----------------------------------------------------------------------------
# Stripe Payments — REQUIRED for billing
# Get keys at: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (subscriptions) — REQUIRED for checkout
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_CREATOR=price_xxx
STRIPE_PRICE_STUDIO=price_xxx

# Stripe Price IDs (add-on token packages) — optional
STRIPE_PRICE_TOKEN_SPARK=price_xxx
STRIPE_PRICE_TOKEN_BLAZE=price_xxx
STRIPE_PRICE_TOKEN_INFERNO=price_xxx

# -----------------------------------------------------------------------------
# Encryption — REQUIRED
# AES-256-GCM key for encrypting BYOK API keys at rest (exactly 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_MASTER_KEY=your-64-char-hex-string

# -----------------------------------------------------------------------------
# Platform API Keys (used for Studio tier users who don't bring their own)
# All optional — features degrade gracefully when missing
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx
PLATFORM_MESHY_KEY=xxx
PLATFORM_HYPER3D_KEY=xxx
PLATFORM_ELEVENLABS_KEY=xxx
PLATFORM_SUNO_KEY=xxx

# Third-party generation providers (direct keys — used when platform key not set)
MESHY_API_KEY=msy_...
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# Alternative AI providers (fallback routing)
AI_GATEWAY_API_KEY=
OPENROUTER_API_KEY=
GITHUB_MODELS_PAT=ghp_...
GOOGLE_AI_API_KEY=

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting) — optional
# Get keys at: https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry) — optional, no-ops when missing
# Get DSN at: https://sentry.io
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -----------------------------------------------------------------------------
# Application URL — optional, defaults to http://localhost:3000
# Set in production to your actual domain (used for Stripe redirect URLs)
#
# With portless (npm run dev), the local dev URL is:
#   https://spawnforge.localhost
# Git worktrees get branch subdomains automatically, e.g.:
#   https://feat-pf-822.spawnforge.localhost
# Use "npm run dev:raw" to bypass portless and access via localhost:3000.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Environment — optional, defaults to NODE_ENV
# Set to "staging" on staging deployments for environment-aware behavior
# Vercel auto-fills VERCEL_ENV, VERCEL_GIT_COMMIT_SHA, VERCEL_URL
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ENVIRONMENT=staging
# STAGING_URL=https://staging.spawnforge.ai  # Required for CORS on staging deployments

# -----------------------------------------------------------------------------
# Admin Access — optional
# Comma-separated Clerk user IDs that have admin privileges (/admin routes)
# -----------------------------------------------------------------------------
# ADMIN_USER_IDS=user_xxx,user_yyy

# Cron job authentication secret — set in Vercel, must match in cron routes
# CRON_SECRET=your-secret-here

# Comma-separated blocked words for AI content moderation
# MODERATION_BLOCK_LIST=

# Desktop tool integration: absolute path to Aseprite binary
# ASEPRITE_PATH=/Applications/Aseprite.app/Contents/MacOS/aseprite

# Log level for server-side structured logging (debug | info | warn | error)
# LOG_LEVEL=info

# Feature flag: set to "1" to use AI SDK v5 adapter (experimental)
# USE_AI_SDK=

# Set to "true" in CI when running `next start` without full env (skips validation)
# SKIP_ENV_VALIDATION=

# -----------------------------------------------------------------------------
# AI Deep-Generation Tier — optional, default off
# Routes GDD, world builder, and cutscene generators to Opus 4.7 (AI_MODEL_DEEP)
# when set to exactly "true". Any other value (including "1", "on") keeps the
# primary tier (Sonnet 4.6). See docs/decisions/2026-05-01-opus-deep-tier.md.
# Safe to expose client-side: only toggles which model string is sent to
# /api/chat; all routing decisions happen server-side on every request.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_USE_DEEP_GENERATION=true

# -----------------------------------------------------------------------------
# WASM Engine CDN — optional, defaults to same-origin (local dev)
# Set to your Cloudflare R2 public URL for production deployments.
# CSP headers auto-allow this origin for script-src and connect-src.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ENGINE_CDN_URL=https://cdn.spawnforge.ai

# -----------------------------------------------------------------------------
# Asset CDN & Storage — optional, defaults to localhost
# Comma-separated list of allowed CDN hosts for asset downloads
# -----------------------------------------------------------------------------
# ASSET_CDN_HOSTS=cdn.your-domain.com

# Object storage for asset uploads (marketplace). Without this, upload returns 501.
# ASSET_STORAGE_TYPE=r2
# ASSET_BUCKET_NAME=spawnforge-assets
# ASSET_R2_ACCOUNT_ID=xxx
# ASSET_R2_ACCESS_KEY_ID=xxx
# ASSET_R2_SECRET_ACCESS_KEY=xxx

# -----------------------------------------------------------------------------
# Vercel Skew Protection (auto-set by Vercel — do NOT set manually)
# These are system env vars injected by Vercel when Skew Protection is enabled.
# Enable via: Vercel Dashboard > Project > Settings > Advanced > Skew Protection
# Requires "Automatically expose system environment variables" to be ON.
# Next.js 14.1.4+ handles version pinning automatically once enabled.
# Docs: https://vercel.com/docs/skew-protection
# -----------------------------------------------------------------------------
# VERCEL_SKEW_PROTECTION_ENABLED=1          # Set to "1" by Vercel when active
# VERCEL_DEPLOYMENT_ID=dpl_xxx              # Unique ID for the current deployment
